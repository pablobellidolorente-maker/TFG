Con esto en el log tendremos:

- "Write Logs --> que se encarga de parametrizar el log, dandole los niveles de error, donde se va a encontrar, el nombre que va a tener, fecha....
- "Test-IsAdmin" / "Requiere-Admin" --> Estas estan puestas para la configuración (creo que tendremos que quitarlo pero que por ahora este no me parece mal) obliga que se este ejecutando con permisos de administrador, esto es
para saltarse firewall
- "Invoke-Safely" --> Este comando nos indica que se ha iniciado la ejecución y si el sresultado es correcto, en caso de serlo genial, y si no con el "catch" nos devuelve el error y nos dice que tipo.
- "Import-ConfigFile" --> Esto lo que hace es indicarnos que si el archivo existe o no, en caso de no exisitir así podremos saber que no se esta ejectuando sobre nada, y si si existe nos idicara que efectivamente se ha 
procedido con la ejecución. Y por último manda los resultados a la ruta que le indiquemos.




<#
.SYNOPSIS
    Módulo de utilidades para TFG-AutoDeploy.

.DESCRIPTION
    Contiene funciones comunes para logging, comprobación de permisos,
    ejecución segura e importación de configuraciones.
#>

# ============================
#   CONFIGURACIÓN GENERAL
# ============================

# Ruta base del proyecto (carpeta donde está launcher.ps1)
$Global:ProjectRoot = Split-Path -Parent $PSScriptRoot

# Carpeta de logs
$Global:LogPath = Join-Path $ProjectRoot "logs"

# Crear carpeta de logs si no existe
if (-not (Test-Path $LogPath)) {
    New-Item -Path $LogPath -ItemType Directory | Out-Null
}

# ============================
#   FUNCIÓN: Write-Log
# ============================
function Write-Log {
    param(
        [Parameter(Mandatory=$true)]
        [string]$Message,

        [ValidateSet("INFO","WARN","ERROR")]
        [string]$Level = "INFO"
    )

    $timestamp = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    $logFile = Join-Path $LogPath "$(Get-Date -Format 'yyyy-MM-dd').log"

    $entry = "[$timestamp] [$Level] $Message"

    Add-Content -Path $logFile -Value $entry
}

# ============================
#   FUNCIÓN: Test-IsAdmin
# ============================
function Test-IsAdmin {
    $currentUser = [Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = New-Object Security.Principal.WindowsPrincipal($currentUser)
    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

# ============================
#   FUNCIÓN: Require-Admin
# ============================
function Require-Admin {
    if (-not (Test-IsAdmin)) {
        Write-Log -Message "El script requiere privilegios de administrador." -Level "ERROR"
        Write-Host "❌ Este script debe ejecutarse como administrador."
        exit 1
    }
}

# ============================
#   FUNCIÓN: Invoke-Safely
# ============================
function Invoke-Safely {
    param(
        [Parameter(Mandatory=$true)]
        [scriptblock]$Action,

        [string]$Description = "Acción sin descripción"
    )

    try {
        Write-Log -Message "Iniciando: $Description"
        & $Action
        Write-Log -Message "Completado: $Description"
    }
    catch {
        Write-Log -Message "ERROR en '$Description': $_" -Level "ERROR"
        Write-Host "❌ Error ejecutando: $Description"
    }
}

# ============================
#   FUNCIÓN: Import-ConfigFile
# ============================
function Import-ConfigFile {
    param(
        [Parameter(Mandatory=$true)]
        [string]$Path
    )

    if (-not (Test-Path $Path)) {
        Write-Log -Message "Archivo de configuración no encontrado: $Path" -Level "ERROR"
        throw "No se encontró el archivo de configuración: $Path"
    }

    Write-Log -Message "Cargando archivo de configuración: $Path"
    return Get-Content -Path $Path
}

Export-ModuleMember -Function * -Variable ProjectRoot,LogPath
